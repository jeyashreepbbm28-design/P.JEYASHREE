class Solution:
    def isMatch(self, s: str, p: str) -> bool:
        memo = {}

        def dp(i, j):
            # If we've already calculated this state, return it
            if (i, j) in memo:
                return memo[(i, j)]
            
            # Base case: if we reach the end of the pattern
            if j == len(p):
                return i == len(s)

            # Check if the current characters match
            first_match = i < len(s) and (p[j] == s[i] or p[j] == '.')

            # Handle the '*' wildcard
            if j + 1 < len(p) and p[j+1] == '*':
                # Option 1: Skip the 'char*' (match zero times)
                # Option 2: Use the '*' (if first_match is True, move string pointer 'i')
                res = dp(i, j + 2) or (first_match and dp(i + 1, j))
            else:
                # No '*', move both pointers forward if they match
                res = first_match and dp(i + 1, j + 1)

            memo[(i, j)] = res
            return res

        return dp(0, 0)
