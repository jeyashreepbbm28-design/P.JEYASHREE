class Solution:
    def firstMissingPositive(self, nums: List[int]) -> int:
        n = len(nums)
        
        for i in range(n):
            # While the current number is in the valid range [1, n]
            # and is NOT at its correct index (nums[i] - 1), swap it.
            # We use a while loop because the swapped number also needs checking.
            while 1 <= nums[i] <= n and nums[nums[i] - 1] != nums[i]:
                # Swap nums[i] with the element at its target position
                correct_idx = nums[i] - 1
                nums[i], nums[correct_idx] = nums[correct_idx], nums[i]
        
        # After sorting, the first index 'i' where nums[i] != i + 1 
        # tells us that 'i + 1' is the missing positive.
        for i in range(n):
            if nums[i] != i + 1:
                return i + 1
        
        # If all numbers 1 to n are present, the answer is n + 1
        return n + 1
